# Tracker (your Render service)
TRACKER_URL=https://YOUR-SERVICE-NAME.onrender.com

# Token shared with the tracker's COOKIE_SYNC_TOKEN env var.
# Used to pull the current cookie from /api/poller/cookie/export during
# automated refresh. Generate one: openssl rand -hex 32
COOKIE_SYNC_TOKEN=

# Bitget login — only needed for a FULL re-login (npm run login).
# The silent refresh / GitHub Action does NOT need these.
BITGET_PHONE=
BITGET_PASSWORD=

# --- Legacy direct-scraper settings (only if you run scraper.js on a VPS) ---
BITGET_PAGE=https://www.bitget.com/copy-trading/mt5/follower/detail?portfolioId=YOUR_PORTFOLIO_ID
PORTFOLIO_ID=YOUR_PORTFOLIO_ID
POLL_INTERVAL_MS=60000
SCRAPE_INTERVAL_MS=30000
REFRESH_INTERVAL_MS=3600000
